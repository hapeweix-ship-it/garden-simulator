{
  "name": "Python Codespace",

  "image": "mcr.microsoft.com/devcontainers/python:3.12",

    "features": {
        "ghcr.io/devcontainers/features/github-cli:latest": {}
    },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "workbench.colorTheme": "Dark Modern",
        "chat.disableAIFeatures": true,
        "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": false,
        "github.copilot.nextEditSuggestions.enabled": false,
        "github.copilot.nextEditSuggestions.fixes": false,
        "editor.inlineSuggest.enabled": false,
        "editor.suggest.preview": false
      }
    }
  },

  "postCreateCommand": "code --uninstall-extension github.copilot-chat --force || true"
}